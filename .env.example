# Copy to .env for local Docker Compose runs and replace every value.
JUMP_USER=admin
JUMP_PASS=replace-with-the-admin-password
DEVELOPER_USER=developer
DEVELOPER_PASS=replace-with-the-developer-password
OPS_USER=ops
OPS_PASS=replace-with-the-ops-password
SERVER_USERS=admin:replace-with-the-admin-password,developer:replace-with-the-developer-password,ops:replace-with-the-ops-password
CLUSTER_SHARED_TOKEN=replace-with-a-random-cluster-token
ADMIN_TOKEN=replace-with-a-random-admin-token
AGENT_ROOT_PASSWORD=replace-with-a-strong-target-password
